                print("- Melhor enquadramento detectado")

            # Sugestões para documentos
            if tipo_conteudo == "documento":
                print("- Nitidez de texto aumentada")
                print("- Contraste otimizado para leitura")

            # Sugestões para slides
            if tipo_conteudo == "slide":
                print("- Correção de alinhamento aplicada")
                print("- IA identificou apresentação")

            # Sugestões para quadro
            if tipo_conteudo == "quadro":
                print("- Perspectiva corrigida")
                print("- Realce de escrita ativado")

            # Sugestões para ambiente sala de aula
            if ambiente == "sala de aula":
                print("- Modo estudo ativado")
                print("- Foco automático em textos")

            # Sugestões para biblioteca
            if ambiente == "biblioteca":
                print("- Captura discreta otimizada")
                print("- Modo não perturbe")

            # Sugestões para ambiente externo
            if ambiente == "ambiente externo":
                print("- Ajuste automático de brilho solar")
                print("- Redução de reflexos aplicada")

            # Sugestões para baixa qualidade
            if qualidade == "baixa":
                print("- IA recomenda estabilizar o celular")
                print("- Sugestão de melhorar iluminação")

            # Sugestões para qualidade média
            if qualidade == "média":
                print("- Ajustes automáticos aplicados")

            # Sugestões para alta qualidade
            if qualidade == "alta":
                print("- Captura otimizada com sucesso")

            # Sugestões para imagens tremidas
            if movimento == "sim":
                print("- Estabilização inteligente ativada")
                print("- IA recomenda manter a câmera fixa")

            # Pergunta se deseja voltar ao menu
            voltar = input(
                "\nDeseja voltar ao menu? (s/n): "
            ).lower()

            # Retorna ao menu principal
            if voltar == "s":
                break

        # Tratamento de erros gerais
        except:
            print("Ocorreu um erro.")


# Função responsável por exibir a galeria
def visualizar_galeria():

    while True:

        try:

            print("\n===== GALERIA JOVI =====")

            # Verifica se a galeria está vazia
            if len(galeria) == 0:
                print("Nenhuma imagem salva.")

            else:

                contador = 1

                # Percorre todas as imagens da galeria
                for imagem in galeria:

                    # Exibe os dados da imagem
                    print(f"""{contador} -
                        Nome: {imagem[0]}
                        Categoria: {imagem[1]}
                        Qualidade: {imagem[2]}
                        Data: {imagem[3]}""")

                    contador += 1

            # Pergunta se deseja voltar ao menu
            voltar = input(
                "Deseja voltar ao menu? (s/n): "
            ).lower()

            # Retorna ao menu principal
            if voltar == "s":
                break

        # Tratamento de erros gerais
        except:
            print("Ocorreu um erro.")


# Inicialização do sistema
menu()
